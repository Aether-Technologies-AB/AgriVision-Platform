generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenant root ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  farms   Farm[]
  apiKeys ApiKey[]
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  passwordHash   String
  role           UserRole     @default(OPERATOR)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

enum UserRole {
  OWNER
  OPERATOR
  VIEWER
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  prefix         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  farmId         String?
  farm           Farm?        @relation(fields: [farmId], references: [id])
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([keyHash])
  @@index([organizationId])
}

// ─── Farm structure ───

model Farm {
  id             String       @id @default(cuid())
  name           String
  address        String?
  timezone       String       @default("Europe/Stockholm")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  // Cost defaults
  electricityPriceKrPerKwh   Float @default(1.50)
  defaultSubstrateCostPerBag Float @default(15.0)
  defaultLaborCostPerBatch   Float @default(200.0)
  defaultMarketPrices        Json? // e.g. {"oyster_blue": 150, "lions_mane": 250}

  zones          Zone[]
  apiKeys        ApiKey[]
  deviceStates   DeviceState[]
  energyReadings EnergyReading[]

  @@index([organizationId])
}

model Zone {
  id     String @id @default(cuid())
  name   String
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  cameraType String?
  sensorUrl  String?
  plugIds    Json?

  agentStatus   AgentStatus @default(OFFLINE)
  agentLastSeen DateTime?
  currentPhase  GrowthPhase @default(IDLE)
  autoMode      Boolean     @default(true)

  // Optional — the family this zone usually runs. Used to (a) pre-select the
  // family picker in the New Batch form, and (b) resolve the agent's
  // /api/agent/batch upsert when it doesn't send `cropFamily` explicitly.
  // NULL means "no default", not "any family allowed" — a Pi upsert against
  // such a zone with no explicit family will be rejected (no silent guess).
  defaultCropFamily CropFamily?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches          Batch[]
  sensorReadings   SensorReading[]
  photos           Photo[]
  deviceStates     DeviceState[]
  commands         Command[]
  energyReadings   EnergyReading[]
  siteObservations SiteObservation[]

  @@index([farmId])
}

enum AgentStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum GrowthPhase {
  IDLE
  COLONIZATION
  FRUITING
  HARVESTING
  DRYING
}

// ─── Core data ───

model Batch {
  id          String @id @default(cuid())
  batchNumber String @unique
  zoneId      String
  zone        Zone   @relation(fields: [zoneId], references: [id])

  // Family drives which phase set + which family-specific fields apply.
  // Nullable at the column level until the PR 3 migration flips it to NOT
  // NULL; PR 1 code paths refuse to create a Batch without one.
  cropFamily CropFamily?
  // Variety within the family — free string ("Sakura", "oyster_blue", …).
  cropType   String

  // Mushroom-only fields. Nullable so a MICROGREEN batch can leave them null.
  // The mushroom-side "straw" default is intentionally gone: it silently
  // labelled every batch (including microgreens) as substrate=straw.
  substrate String?
  bagCount  Int?

  // Microgreen-only fields. Nullable for MUSHROOM batches.
  trayCount          Int?
  seedingDensityGSqm Float?
  growthDay          Int?

  // Production unit for individually-spaced crops (basil, lettuce). Unlike
  // seedingDensityGSqm (a seeded mat by weight), leafy greens are countable
  // plants — "32 basil plants in 1 tray". Nullable for families that don't
  // count individual plants.
  plantCount Int?

  substrateCost Float?
  laborCost     Float?

  phase       BatchPhase @default(PLANNED)
  plantedAt   DateTime?
  fruitingAt  DateTime?
  harvestedAt DateTime?

  estHarvestDate DateTime?
  estYieldKg     Float?
  estProfit      Float?

  actualYieldKg Float?
  actualRevenue Float?
  actualCost    Float?
  actualProfit  Float?
  qualityGrade  String?

  healthScore Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiDecisions      AIDecision[]
  harvests         Harvest[]
  scheduleEvents   ScheduleEvent[]
  sensorReadings   SensorReading[]
  photos           Photo[]
  siteObservations SiteObservation[]

  @@index([zoneId])
  @@index([phase])
}

enum BatchPhase {
  PLANNED
  COLONIZATION
  FRUITING
  READY_TO_HARVEST
  HARVESTED
  CANCELLED
  GERMINATION
  POST_GERMINATION
  ACTIVE_GROWING
  PRE_HARVEST
}

// Crop family determines which BatchPhase values are legal on a Batch and
// which family-specific fields are populated. See src/lib/crop-family.ts for
// the phase/field split — the DB CHECK constraint that enforces the pairing
// lands in PR 3 (holding this here as an app-level invariant for PR 1).
enum CropFamily {
  MUSHROOM
  MICROGREEN
  // Added for the Pilot Basement lettuce/basil trait-ingestion pipeline
  // (SiteObservation). Additive only — MUSHROOM/MICROGREEN rows and code
  // paths are untouched. Not yet wired into any phase/field split; batches
  // in Floor 1/Floor 2 don't exist yet for this crop family.
  LEAFY_GREEN
}

model SensorReading {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  // Resolved server-side at ingest via getActiveBatchId — nullable because a
  // reading with no active batch in its zone is valid and must still be
  // stored (see src/lib/active-batch.ts).
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)

  // AIR temp/humidity are nullable so a dedicated water/CO2 agent can push a
  // reading WITHOUT air data (a separate agent owns the air readings on the
  // same zone). Air-only agents keep sending both — unchanged.
  temperature Float? // AIR temperature in °C (do NOT overload with water temp)
  humidity    Float?
  co2         Int?
  vpd         Float?
  battery     Int?

  // Water-chemistry / reservoir sensing (Atlas Scientific EZO probes).
  // All nullable — only zones with an EZO reservoir probe populate these;
  // every other zone leaves them NULL and is unaffected.
  ph        Float? // water pH (dimensionless, ~0–14)
  ec        Float? // water electrical conductivity in µS/cm (EZO-EC native unit)
  waterTemp Float? // water/reservoir temperature in °C — distinct from `temperature` (= AIR temp)

  timestamp DateTime @default(now())

  @@index([zoneId, timestamp])
  @@index([timestamp])
  @@index([batchId])
}

model Photo {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  // Resolved server-side at ingest via getActiveBatchId — same nullability
  // rationale as SensorReading.batchId above.
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)

  rgbUrl   String
  depthUrl String?

  analysis Json?

  // Cloud photo retention: cap is enforced per zone (see src/lib/photo-retention.ts).
  // When set, the rgb/depth blobs have been deleted from storage to free quota —
  // this row (and `analysis`, used as ML training labels) is kept regardless.
  // rgbUrl/depthUrl are stale once pruned; consumers that render images must
  // filter on prunedAt, not on URL presence.
  prunedAt DateTime?

  // Inference-worker contract: null = needs detection, set = a worker has
  // posted a result (ok or failed) via POST /api/analysis/results. Set on
  // both outcomes so a bad image can't be re-pulled forever.
  analyzedAt DateTime?

  timestamp DateTime @default(now())

  siteObservations SiteObservation[]

  @@index([zoneId, timestamp])
  @@index([batchId])
  @@index([analyzedAt])
}

model AIDecision {
  id      String  @id @default(cuid())
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  decisionType DecisionType
  decision     String
  reasoning    String
  actionTaken  String?

  sensorContext Json?
  mlContext     Json?

  costKr Float?

  timestamp DateTime @default(now())

  @@index([batchId, timestamp])
  @@index([decisionType])
  @@index([timestamp])
}

enum DecisionType {
  ENVIRONMENT
  VISION
  HARVEST
  SCHEDULE
  ALERT
  STRATEGIC
}

model Harvest {
  id      String @id @default(cuid())
  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  weightKg     Float
  qualityGrade String
  pricePerKg   Float
  revenue      Float

  energyCost    Float?
  substrateCost Float?
  laborCost     Float?
  totalCost     Float?
  profit        Float?
  costPerGram   Float?

  harvestedAt DateTime @default(now())

  @@index([batchId])
}

model ScheduleEvent {
  id      String  @id @default(cuid())
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  eventType   ScheduleEventType
  title       String
  description String?
  scheduledAt DateTime
  completedAt DateTime?
  status      EventStatus       @default(PENDING)

  createdAt DateTime @default(now())

  @@index([scheduledAt])
  @@index([status])
}

enum ScheduleEventType {
  INOCULATION
  PHASE_CHANGE
  VISION_CHECK
  HARVEST_WINDOW
  DELIVERY
  MAINTENANCE
  CUSTOM
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

enum DeviceScope {
  ZONE
  FARM
}

model DeviceState {
  id     String      @id @default(cuid())
  farmId String
  farm   Farm        @relation(fields: [farmId], references: [id])
  zoneId String?
  zone   Zone?       @relation(fields: [zoneId], references: [id])
  scope  DeviceScope @default(ZONE)

  deviceType  DeviceType
  deviceName  String
  state       Boolean
  lastToggled DateTime?

  updatedAt DateTime @updatedAt

  @@unique([farmId, scope, deviceType, deviceName])
  @@index([farmId])
  @@index([zoneId])
}

enum DeviceType {
  HUMIDIFIER
  FAN
  LIGHT
  HEATER
  PUMP
}

model EnergyReading {
  id     String  @id @default(cuid())
  farmId String
  farm   Farm    @relation(fields: [farmId], references: [id])
  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  deviceName String
  // kWh = the raw counter value the Pi reported on this poll (Shelly
  // aenergy.total = lifetime cumulative; Tapo today_wh = cumulative-since-
  // midnight). Kept for audit + recompute. NOT what dashboards should sum.
  kWh        Float
  // deltaKwh = consumption since the previous poll for this device, computed
  // at ingest from the running counter and DeviceEnergyState. This is the
  // field every read path must sum. Nullable so rows that pre-date the
  // delta-at-ingest fix stay distinguishable from a genuine 0 delta.
  deltaKwh   Float?
  costKr     Float?

  timestamp DateTime @default(now())

  @@index([farmId, timestamp])
  @@index([zoneId, timestamp])
}

// Per-device running counter, used to derive deltaKwh on the next ingest.
// Keyed by (farmId, deviceName) — device names are assumed unique within a
// farm (e.g. "light", "Main Humidifier"). If two zones in the same farm need
// to host devices with the same name, rename one — there is no zone scoping
// here on purpose, because Tapo/Shelly counters are device-local, not
// zone-local.
model DeviceEnergyState {
  id             String   @id @default(cuid())
  farmId         String
  deviceName     String
  // The last counter value we saw from this device. On the next reading we
  // compute current - lastCounterKwh; if current < lastCounterKwh we treat it
  // as a counter reset (Shelly reboot / Tapo midnight rollover) and bill the
  // new reading as the delta.
  lastCounterKwh Float
  updatedAt      DateTime @updatedAt

  @@unique([farmId, deviceName])
}

model Command {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  command    String
  payload    Json?
  source     CommandSource @default(MANUAL)
  status     CommandStatus @default(PENDING)
  issuedAt   DateTime      @default(now())
  executedAt DateTime?
  result     String?

  @@index([zoneId, status])
}

enum CommandStatus {
  PENDING
  ACKNOWLEDGED
  EXECUTED
  FAILED
  EXPIRED
}

enum CommandSource {
  MANUAL
  RULE
  AI
}

// ─── ML Model Registry ───

model MLModel {
  id       String @id @default(cuid())
  name     String
  version  String
  cropType String

  fileUrl    String
  fileSizeMb Float
  accuracy   Float?

  trainedOn String?
  epochs    Int?

  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([name, version])
  @@index([name, isActive])
}

// ─── Lettuce/basil trait ingestion (Pilot Basement pilot) ───
//
// One row per (rail, cycleId, siteId, viewAngleDeg) trait record produced by
// an off-platform GPU box running detection locally on RGB-D camera-rail
// scans. Images stay on the GPU box; only traits + a few representative
// photos travel. A "site" is a physical net-pot (e.g. "row06_ch2"), imaged
// from 3 rail stops per cycle (~-18/0/+18deg off-nadir) plus one FUSED
// record merging those views into a 3D reconstruction — up to 4 rows per
// site per cycle. Traits are recorded even for an empty/rejected pot so
// drift is visible rather than silent (see plantPresent/rejectReason).
//
// This exists to serve one query fast and indexed, not via a JSON scan:
// "site X's canopy volume over the last 8 weeks" -> @@index([siteId, capturedAt]).
//
// Additive-only alongside Photo/Batch/Zone: no existing column was touched
// to add this. Rail<->zone mapping lives in src/lib/rail-zones.ts (app-level
// config), not a schema column — see that file for why.
model SiteObservation {
  id String @id @default(cuid())

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  // Resolved server-side via the same getActiveBatchId() helper
  // /api/agent/photo uses — null is valid (no active batch in this zone yet).
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)

  // Traceability to the representative image, if one was uploaded for this
  // record. Most records won't have one — only "a few representative images"
  // travel per the pipeline design.
  photoId String?
  photo   Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)

  rail    String // "rail1" | "rail2" — validated against zone at ingest
  cycleId String // e.g. "2026-07-16_12-27-24", one GPU-box run over the rail
  siteId  String // permanent physical net-pot id, e.g. "row06_ch2"

  globalRow Int
  channel   Int
  stop      Int

  // Null for the FUSED record (producer sends the literal string "fused"
  // there, not a number) — isFused is the authoritative flag, this is null
  // only in that one case.
  viewAngleDeg  Float?
  isFused       Boolean @default(false)
  isPrimaryView Boolean
  nViewsFused   Int? // fused records only, e.g. 3
  fusionGainPct Float? // fused records only

  capturedAt DateTime

  plantPresent Boolean
  rejectReason String?

  areaPx          Int?
  areaCm2         Float?
  canopyVolumeCm3 Float?
  heightMmMax     Float?
  heightMmMean    Float?
  heightProfileMm Json?
  widthMm         Float?
  lengthMm        Float?
  coverage        Float?
  exgMean         Float?
  exgStd          Float?
  labAMean        Float?
  deepGreenFrac   Float?
  depthValidPct   Float?
  clippedByRoi    Boolean?

  channelPlaneMm Float?
  fx             Float?

  // Not calibrated yet — always null until a calibration pass exists.
  // See src/app/api/observations/route.ts: the endpoint forces this to
  // null server-side regardless of what a producer sends.
  freshWeightGEst    Float?
  calibrationVersion String?

  schemaVersion Int

  createdAt DateTime @default(now())

  // ============================================================================
  // !! THIS DECLARATION IS A STAND-IN, NOT THE REAL CONSTRAINT !!
  //
  // The REAL constraint is `... NULLS NOT DISTINCT`, and it lives ONLY in the
  // hand-written SQL of migration 20260717115014_add_site_observation_and_leafy_green
  // (prisma/migrations/20260717115014_add_site_observation_and_leafy_green/migration.sql).
  // Prisma's schema DSL (confirmed against Prisma 7.5) has no way to express
  // NULLS NOT DISTINCT — `@@unique(..., nullsNotDistinct: true)` fails schema
  // validation with "No such argument" — so the line below is a plain UNIQUE,
  // present only so the Prisma Client has a typed compound-unique key to
  // upsert against.
  //
  // A plain UNIQUE treats every NULL as distinct from every other NULL. The
  // FUSED row (viewAngleDeg IS NULL, isFused true) relies entirely on
  // NULLS NOT DISTINCT to dedupe on repost. If `prisma migrate dev` (or any
  // diff/regeneration tool) is ever run against this model — e.g. after the
  // corrupted baseline migration (20260712190829_baseline, stray dotenv log
  // on line 1) is eventually fixed and shadow-DB diffing starts working again
  // — it WILL propose "fixing" this index back to a plain UNIQUE, and that
  // change WILL SILENTLY BREAK FUSED-ROW IDEMPOTENCY: every repost of a
  // cycle would then insert a brand-new duplicate fused row instead of
  // updating the existing one, with no error raised anywhere.
  //
  // src/app/api/observations/route.test.ts is the guard against this — it
  // asserts a fused record reposted twice still resolves to exactly one row.
  // If that test ever starts failing, this is why: check the live index with
  //   SELECT pg_get_indexdef(indexrelid) FROM pg_index
  //   WHERE indrelid = '"SiteObservation"'::regclass;
  // and confirm "NULLS NOT DISTINCT" is still present. If a migration
  // regenerated this constraint without it, hand-add NULLS NOT DISTINCT back
  // to the generated CREATE UNIQUE INDEX statement before applying.
  // ============================================================================
  @@unique([rail, cycleId, siteId, viewAngleDeg, isFused])
  @@index([siteId, capturedAt])
  @@index([zoneId, capturedAt])
  @@index([cycleId])
}
