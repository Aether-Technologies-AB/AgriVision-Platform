generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenant root ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  farms   Farm[]
  apiKeys ApiKey[]
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  passwordHash   String
  role           UserRole     @default(OPERATOR)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

enum UserRole {
  OWNER
  OPERATOR
  VIEWER
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  prefix         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  farmId         String?
  farm           Farm?        @relation(fields: [farmId], references: [id])
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([keyHash])
  @@index([organizationId])
}

// ─── Farm structure ───

model Farm {
  id             String       @id @default(cuid())
  name           String
  address        String?
  timezone       String       @default("Europe/Stockholm")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  // Cost defaults
  electricityPriceKrPerKwh  Float @default(1.50)
  defaultSubstrateCostPerBag Float @default(15.0)
  defaultLaborCostPerBatch   Float @default(200.0)
  defaultMarketPrices        Json? // e.g. {"oyster_blue": 150, "lions_mane": 250}

  zones          Zone[]
  apiKeys        ApiKey[]
  deviceStates   DeviceState[]
  energyReadings EnergyReading[]

  @@index([organizationId])
}

model Zone {
  id     String @id @default(cuid())
  name   String
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  cameraType  String?
  sensorUrl   String?
  plugIds     Json?

  agentStatus   AgentStatus @default(OFFLINE)
  agentLastSeen DateTime?
  currentPhase  GrowthPhase @default(IDLE)
  autoMode      Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches        Batch[]
  sensorReadings SensorReading[]
  photos         Photo[]
  deviceStates   DeviceState[]
  commands       Command[]
  energyReadings EnergyReading[]

  @@index([farmId])
}

enum AgentStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum GrowthPhase {
  IDLE
  COLONIZATION
  FRUITING
  HARVESTING
  DRYING
}

// ─── Core data ───

model Batch {
  id          String     @id @default(cuid())
  batchNumber String     @unique
  zoneId      String
  zone        Zone       @relation(fields: [zoneId], references: [id])

  cropType  String
  substrate String     @default("straw")
  bagCount  Int

  substrateCost Float?
  laborCost     Float?

  phase       BatchPhase @default(PLANNED)
  plantedAt   DateTime?
  fruitingAt  DateTime?
  harvestedAt DateTime?

  estHarvestDate DateTime?
  estYieldKg     Float?
  estProfit      Float?

  actualYieldKg Float?
  actualRevenue Float?
  actualCost    Float?
  actualProfit  Float?
  qualityGrade  String?

  healthScore Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiDecisions    AIDecision[]
  harvests       Harvest[]
  scheduleEvents ScheduleEvent[]

  @@index([zoneId])
  @@index([phase])
}

enum BatchPhase {
  PLANNED
  COLONIZATION
  FRUITING
  READY_TO_HARVEST
  HARVESTED
  CANCELLED
  GERMINATION
  POST_GERMINATION
  ACTIVE_GROWING
  PRE_HARVEST
}

model SensorReading {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  temperature Float // AIR temperature in °C (do NOT overload with water temp)
  humidity    Float
  co2         Int?
  vpd         Float?
  battery     Int?

  // Water-chemistry / reservoir sensing (Atlas Scientific EZO probes).
  // All nullable — only zones with an EZO reservoir probe populate these;
  // every other zone leaves them NULL and is unaffected.
  ph        Float? // water pH (dimensionless, ~0–14)
  ec        Float? // water electrical conductivity in µS/cm (EZO-EC native unit)
  waterTemp Float? // water/reservoir temperature in °C — distinct from `temperature` (= AIR temp)

  timestamp DateTime @default(now())

  @@index([zoneId, timestamp])
  @@index([timestamp])
}

model Photo {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  rgbUrl   String
  depthUrl String?

  analysis Json?

  timestamp DateTime @default(now())

  @@index([zoneId, timestamp])
}

model AIDecision {
  id      String @id @default(cuid())
  batchId String?
  batch   Batch? @relation(fields: [batchId], references: [id])

  decisionType DecisionType
  decision     String
  reasoning    String
  actionTaken  String?

  sensorContext Json?
  mlContext     Json?

  costKr Float?

  timestamp DateTime @default(now())

  @@index([batchId, timestamp])
  @@index([decisionType])
  @@index([timestamp])
}

enum DecisionType {
  ENVIRONMENT
  VISION
  HARVEST
  SCHEDULE
  ALERT
  STRATEGIC
}

model Harvest {
  id      String @id @default(cuid())
  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  weightKg     Float
  qualityGrade String
  pricePerKg   Float
  revenue      Float

  energyCost    Float?
  substrateCost Float?
  laborCost     Float?
  totalCost     Float?
  profit        Float?
  costPerGram   Float?

  harvestedAt DateTime @default(now())

  @@index([batchId])
}

model ScheduleEvent {
  id      String @id @default(cuid())
  batchId String?
  batch   Batch? @relation(fields: [batchId], references: [id])

  eventType   ScheduleEventType
  title       String
  description String?
  scheduledAt DateTime
  completedAt DateTime?
  status      EventStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@index([scheduledAt])
  @@index([status])
}

enum ScheduleEventType {
  INOCULATION
  PHASE_CHANGE
  VISION_CHECK
  HARVEST_WINDOW
  DELIVERY
  MAINTENANCE
  CUSTOM
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

enum DeviceScope {
  ZONE
  FARM
}

model DeviceState {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])
  zoneId String?
  zone   Zone?  @relation(fields: [zoneId], references: [id])
  scope  DeviceScope @default(ZONE)

  deviceType  DeviceType
  deviceName  String
  state       Boolean
  lastToggled DateTime?

  updatedAt DateTime @updatedAt

  @@unique([farmId, scope, deviceType, deviceName])
  @@index([farmId])
  @@index([zoneId])
}

enum DeviceType {
  HUMIDIFIER
  FAN
  LIGHT
  HEATER
  PUMP
}

model EnergyReading {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])
  zoneId String?
  zone   Zone?  @relation(fields: [zoneId], references: [id])

  deviceName String
  // kWh = the raw counter value the Pi reported on this poll (Shelly
  // aenergy.total = lifetime cumulative; Tapo today_wh = cumulative-since-
  // midnight). Kept for audit + recompute. NOT what dashboards should sum.
  kWh        Float
  // deltaKwh = consumption since the previous poll for this device, computed
  // at ingest from the running counter and DeviceEnergyState. This is the
  // field every read path must sum. Nullable so rows that pre-date the
  // delta-at-ingest fix stay distinguishable from a genuine 0 delta.
  deltaKwh   Float?
  costKr     Float?

  timestamp DateTime @default(now())

  @@index([farmId, timestamp])
  @@index([zoneId, timestamp])
}

// Per-device running counter, used to derive deltaKwh on the next ingest.
// Keyed by (farmId, deviceName) — device names are assumed unique within a
// farm (e.g. "light", "Main Humidifier"). If two zones in the same farm need
// to host devices with the same name, rename one — there is no zone scoping
// here on purpose, because Tapo/Shelly counters are device-local, not
// zone-local.
model DeviceEnergyState {
  id              String   @id @default(cuid())
  farmId          String
  deviceName      String
  // The last counter value we saw from this device. On the next reading we
  // compute current - lastCounterKwh; if current < lastCounterKwh we treat it
  // as a counter reset (Shelly reboot / Tapo midnight rollover) and bill the
  // new reading as the delta.
  lastCounterKwh  Float
  updatedAt       DateTime @updatedAt

  @@unique([farmId, deviceName])
}

model Command {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  command    String
  payload    Json?
  status     CommandStatus @default(PENDING)
  issuedAt   DateTime      @default(now())
  executedAt DateTime?
  result     String?

  @@index([zoneId, status])
}

enum CommandStatus {
  PENDING
  ACKNOWLEDGED
  EXECUTED
  FAILED
  EXPIRED
}

// ─── ML Model Registry ───

model MLModel {
  id       String @id @default(cuid())
  name     String
  version  String
  cropType String

  fileUrl    String
  fileSizeMb Float
  accuracy   Float?

  trainedOn String?
  epochs    Int?

  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([name, version])
  @@index([name, isActive])
}
